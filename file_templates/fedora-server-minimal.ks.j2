lang en_US.UTF-8
keyboard us
timezone America/Los_Angeles --utc
rootpw --lock
user --name=${username} --groups=wheel --password=${password}
${network_line}
firewall --enabled --service=ssh
services --enabled=sshd,NetworkManager,qemu-guest-agent
selinux --enforcing
reboot

%packages
@^minimal-environment
openssh-server
qemu-guest-agent
sudo
python3
%end

%post --log=/root/ks-post.log
echo "${hostname}" > /etc/hostname
%end
