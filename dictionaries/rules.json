{
  "globals": {
    "datacenter": "lab-a",
    "env": "lab",
    "release": "sample"
  },
  "groups": {
    "core-services": {
      "locals": {
        "configuration": "ansible",
        "datacenter": "lab-a",
        "env": "lab",
        "release": "sample",
        "workflow": "gathered -> accepted -> build -> configure -> validate -> done"
      },
      "nodes": {
        "dns-core-01.example.lab": {
          "configuration": "ansible",
          "fqdn": "dns-core-01.example.lab",
          "hostname": "dns-core-01",
          "ip": "10.20.0.10",
          "port": 22,
          "private_key": "keys/example_id_rsa",
          "provider": "manual-scan",
          "provider_sources": [
            "manual-scan",
            "ansible"
          ],
          "provisioner": "ssh-bootstrap",
          "services_detected": [
            "named",
            "dhcpd"
          ],
          "state": "validate",
          "user": "root"
        },
        "hypervisor-01.example.lab": {
