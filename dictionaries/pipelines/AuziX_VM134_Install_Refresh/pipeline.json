    "iso-build",
    "iso-publish",
    "vm-target-verify",
    "install-handoff"
  ],
  "actions": [
    "repo.source.verify",
    "docker.builder.prepare",
    "auzix.installer_root.build",
    "auzix.iso.build",
    "proxmox.iso.publish",
    "proxmox.vm.install_target.verify"
  ],
  "gates": [
    "source-commit",
    "installer-runtime",
    "grub-runtime",
    "vm134-target-disk",
    "vm134-boot-media"
  ],
  "notes": "First repeatable lane for the newer VM134 target. This intentionally stops at a guarded install handoff until the live installer path is proven from the UI/TUI.",
