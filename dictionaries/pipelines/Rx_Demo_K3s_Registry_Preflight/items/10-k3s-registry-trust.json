{
  "id": "k3s-registry-trust",
  "kind": "operator-check",
  "summary": "Confirm every k3s node has containerd mirror config for the demo registry when using HTTP.",
  "path": "/etc/rancher/k3s/registries.yaml",
  "command": "ssh <k3s-node> 'sudo test -s /etc/rancher/k3s/registries.yaml && sudo grep -F \"<registry-host>:5000\" /etc/rancher/k3s/registries.yaml'"
}

