{
  "id": "rx-demo-k3s-redeploy-from-git",
  "name": "Demo: Rx Demo K3s Redeploy From Git",
  "repo": "rx-demo",
  "workflow": "rx-demo-redeploy-from-git-event",
  "description": "Record a Git-triggered rx-demo change, sync source, build/push commit-tagged images, update k3s, and validate CloudEvents audit records through Loki/Grafana.",
  "stages": [
    "git-event",
    "sync-source-from-git",
    "build-and-push",
    "update-images",
    "rollout-app",
    "cloudinit-node-check",
    "visible-change-check",
    "telemetry-still-flowing",
    "loki-cloudevents-check",
    "grafana-loki-check",
    "access-links"
  ],
  "actions": [
    "git.event.record",
    "git.checkout",
    "docker.buildx.push",
    "kubectl.set_image",
    "kubectl.rollout_status",
    "k3s.node.provenance",
    "http.content_check",
    "prometheus.metrics.check",
    "loki.stream.verify",
    "grafana.datasource.check"
  ],
  "gates": [
    "commit-hash-present",
    "unique-image-tag",
    "rx-demo-rollout-complete",
    "visible-ui-change",
    "cloudevents-audit-in-loki",
    "grafana-loki-ready"
  ],
  "notes": "This is the weekend demo event-trigger lane. It is intentionally broader than ArgoCD: BKC records the operational trigger, deployment action, node/cloud-init evidence, and validation evidence in Loki/Grafana.",
  "editable": true,
  "tags": [
    "rx-demo",
    "demo",
    "video",
    "git",
    "redeploy",
    "k3s",
    "registry",
    "cloudevents",
    "loki",
    "grafana",
    "runnable"
  ]
}
