{% extends 'base.html.j2' %}

{% block title %}Overview{% endblock %}
{% block page_heading %}Overview{% endblock %}

{% block content %}
    <section class="ops-overview">
        <div class="ops-command-panel">
            <div class="section-header">
                <div>
                    <p class="eyebrow">Resource command</p>
                    <h2>Infrastructure by resource, relationship, and action</h2>
                </div>
                <a class="button" href="{{ url_for('resource_graph.resource_graph') }}">Open graph</a>
            </div>
            <section class="resource-metrics overview-resource-metrics">
                {% for kind, meta in resource_kind_meta.items() %}
                    {% if resource_graph.counts.get(kind) %}
                        <a class="resource-metric" href="{{ url_for('resource_graph.resource_graph', kind=kind) }}">
                            <span class="resource-icon">{{ meta.short }}</span>
                            <strong>{{ resource_graph.counts.get(kind) }}</strong>
                            <span>{{ meta.label }}</span>
                        </a>
                    {% endif %}
                {% endfor %}
            </section>
            <div class="overview-resource-list">
                {% for resource in resource_preview %}
                    <a class="overview-resource-row" href="{{ url_for('resource_graph.resource_graph', resource=resource.id) }}">
                        <span class="resource-icon">{{ resource_kind_meta.get(resource.kind, {}).get('short', resource.kind[:3]|upper) }}</span>
                        <strong>{{ resource.name }}</strong>
                        <span>{{ resource.state }}</span>
                        <small>{{ resource.summary }}</small>
                    </a>
                {% else %}
                    <div class="workflow-empty">No resources have been discovered yet.</div>
                {% endfor %}
            </div>
        </div>

        <div class="ops-side-panel">
            <p class="eyebrow">Relationship preview</p>
            <h3>{{ resource_graph.relationships|length }} inferred edges</h3>
            <div class="overview-edge-list">
                {% for relationship in relationship_preview %}
                    <a href="{{ url_for('resource_graph.resource_graph', resource=relationship.source_id, tab='relationships') }}">
                        <strong>{{ relationship.source_label }}</strong>
                        <span>{{ relationship.type }}</span>
                        <strong>{{ relationship.target_label }}</strong>
                    </a>
                {% else %}
                    <div class="workflow-empty">No relationships inferred yet.</div>
                {% endfor %}
            </div>
            <div class="ops-meta-grid">
                <div>
                    <span>Environment</span>
                    <strong>{{ globals_meta.env }}</strong>
                </div>
                <div>
                    <span>Datacenter</span>
                    <strong>{{ globals_meta.datacenter }}</strong>
                </div>
                <div>
                    <span>Release</span>
                    <strong>{{ globals_meta.release }}</strong>
                </div>
                <div>
                    <span>Pipelines</span>
                    <strong>{{ pipelines | length }}</strong>
                </div>
            </div>
        </div>
    </section>

    <section class="card-grid">
        <article class="card metric-card">
            <p class="metric-label">Inventory Groups</p>
            <p class="metric-value">{{ groups | length }}</p>
            <p class="metric-copy">Current groupings available for inventory and staging</p>
        </article>
        <article class="card metric-card">
            <p class="metric-label">Tracked Hosts</p>
            <p class="metric-value">{{ total_hosts }}</p>
            <p class="metric-copy">Hosts currently represented in the tenant inventory</p>
        </article>
        <article class="card metric-card">
            <p class="metric-label">Active Runs</p>
            <p class="metric-value">{{ active_runs }}</p>
            <p class="metric-copy">Pipelines moving or waiting at the executor boundary</p>
        </article>
        <article class="card metric-card">
            <p class="metric-label">Failed Runs</p>
            <p class="metric-value">{{ failed_runs }}</p>
            <p class="metric-copy">Runs that need operator attention, retry, or tighter stage logic</p>
        </article>
    </section>

    <section class="section-header">
        <div>
            <p class="eyebrow">Quick access</p>
            <h3>External consoles</h3>
        </div>
        <a class="button secondary" href="{{ url_for('pipelines.pipelines') }}">Open pipelines</a>
    </section>

    <section class="overview-link-grid">
        {% for link in quick_links %}
            <article class="card overview-link-card">
                <p class="eyebrow">Jump out</p>
                <h4>{{ link.label }}</h4>
                <p class="metric-copy">{{ link.url }}</p>
                <a class="button" href="{{ link.url }}">Open</a>
            </article>
        {% endfor %}
    </section>

    <section class="section-header">
        <div>
            <p class="eyebrow">Grafana direction</p>
            <h3>Dashboard targets</h3>
        </div>
    </section>

    <section class="overview-link-grid">
        {% for dashboard in dashboard_cards %}
            <article class="card overview-link-card">
                <p class="eyebrow">{{ dashboard.pipeline_name }}</p>
                <h4>{{ dashboard.name }}</h4>
                <p class="metric-copy">{{ dashboard.summary }}</p>
                <div class="pipeline-card-actions top-gap-sm">
                    <a class="button" href="{{ dashboard.url }}">Open Grafana</a>
                    <a class="button button-quiet" href="{{ url_for('pipelines.pipelines') }}">Open Pipelines</a>
                </div>
            </article>
        {% endfor %}
    </section>

    <section class="section-header">
        <div>
            <p class="eyebrow">Pipeline state</p>
            <h3>Latest lane status</h3>
        </div>
    </section>

    <section class="overview-link-grid">
        {% for pipeline in pipelines %}
            {% set latest = latest_runs_by_workflow.get(pipeline.workflow) %}
            <article class="card overview-link-card">
                <p class="eyebrow">{{ pipeline.repo }}</p>
                <h4>{{ pipeline.name }}</h4>
                <p class="metric-copy">{{ pipeline.description }}</p>
                {% if latest %}
                    <div class="pipeline-run-meta">
                        <span class="status-pill">{{ latest.status }}</span>
                        <span class="status-pill muted">Run {{ latest.id[:8] }}</span>
                        <span class="status-pill muted">{{ latest.stage_summary.complete }} / {{ latest.stages|length }}</span>
                    </div>
                {% else %}
                    <div class="pipeline-run-meta">
                        <span class="status-pill muted">not started</span>
                    </div>
                {% endif %}
                <div class="pipeline-card-actions top-gap-sm">
                    <a class="button" href="{{ url_for('pipelines.pipelines') }}">Open Pipeline</a>
                    {% if latest %}
                        <a class="button button-quiet" href="{{ url_for('pipelines.pipeline_run_detail', run_id=latest.id) }}">Latest Run</a>
                    {% endif %}
                </div>
            </article>
        {% endfor %}
    </section>

    <section class="section-header">
        <div>
            <p class="eyebrow">Recent automation</p>
            <h3>Run ledger</h3>
        </div>
        <a class="button secondary" href="{{ url_for('pipelines.pipelines') }}">Open all runs</a>
    </section>

    <section class="pipeline-run-list">
        {% for run in recent_runs %}
            <article class="pipeline-run-card">
                <div class="pipeline-card-top">
                    <div>
                        <p class="eyebrow">{{ run.repo }}</p>
                        <h3>{{ run.workflow }}</h3>
                    </div>
                    <span class="status-pill">{{ run.status }}</span>
                </div>
                <p class="metric-copy">{{ run.notes or 'No notes recorded for this run.' }}</p>
                <div class="pipeline-stage-board compact-stage-board">
                    {% for stage in run.stages %}
                        <div class="pipeline-stage-status status-{{ stage.status|lower|replace(' ', '-') }}">
                            <strong>{{ stage.name }}</strong>
                            <span>{{ stage.status }}</span>
                        </div>
                    {% endfor %}
                </div>
                <div class="pipeline-card-actions top-gap-sm">
                    <a class="button" href="{{ url_for('pipelines.pipeline_run_detail', run_id=run.id) }}">Open Run</a>
                </div>
            </article>
        {% else %}
            <section class="group-card empty-state">
                <h4>No automation runs yet</h4>
                <p>Queue a pipeline and the overview will start reflecting real stage activity.</p>
            </section>
        {% endfor %}
    </section>

    <section class="section-header">
        <div>
            <p class="eyebrow">Current inventory</p>
            <h3>Groups</h3>
        </div>
        <a class="button secondary" href="{{ url_for('builder.builder') }}">Open builder</a>
    </section>

    <section class="group-grid">
        {% for group in groups %}
            <article class="group-card">
                <div class="group-card-header">
                    <h4>{{ group.name }}</h4>
                    <span>{{ group.host_count }} hosts</span>
                </div>
                <p><strong>Env:</strong> {{ group.env }}</p>
                <p><strong>Datacenter:</strong> {{ group.datacenter }}</p>
                <div class="stage-chip-row">
                    {% for stage in group.stages %}
                        <span class="stage-chip">{{ stage }}</span>
                    {% endfor %}
                </div>
                <a class="button" href="{{ url_for('groups.hosts', group=group.name) }}">Inspect group</a>
            </article>
        {% else %}
            <article class="group-card empty-state">
                <h4>No groups defined</h4>
                <p>Start by adding a group in the inventory builder, then attach nodes that map to your Proxmox workflow.</p>
            </article>
        {% endfor %}
    </section>
{% endblock %}
