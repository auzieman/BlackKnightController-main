{% extends 'base.html.j2' %}

{% block content %}
  <h2>Command Results:</h2>
  {% for group, results in command_results.items() %}
    <h3>{{ group }}</h3>
    <ul>
      {% for host, result in results.items() %}
        <li><strong>{{ host }}:</strong> {{ result }}</li>
      {% endfor %}
    </ul>
  {% endfor %}
{% endblock %}
