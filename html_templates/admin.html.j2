{% extends 'base.html.j2' %}
{% from '_macros.html.j2' import csrf_field %}
{% block title %}Admin Mode{% endblock %}
{% block page_heading %}Admin Mode{% endblock %}

{% block content %}
    {% if not bkc_perm.remote_exec %}
        <p class="sidebar-copy">Your role is read-only for remote admin. Ask an owner to run SSH or Ansible actions.</p>
    {% endif %}
    <section class="builder-layout">
        <section class="form-shell">
            <div class="section-header">
                <div>
                    <p class="eyebrow">Remote SSH</p>
                    <h2>Run host command</h2>
                </div>
            </div>
            {% if bkc_perm.remote_exec %}
            <form method="post" class="form-grid">
                {{ csrf_field() }}
                <input type="hidden" name="action" value="host-command">
                <label>
                    Group
                    <select name="group">
                        {% for group_data in actionable_inventory %}
                            <option value="{{ group_data.name }}"{% if prefill_group == group_data.name %} selected{% endif %}>{{ group_data.name }}</option>
                        {% endfor %}
                    </select>
                </label>
                <label class="wide">
                    Command
                    <input type="text" name="command" placeholder="hostname && uname -a">
                </label>
                <div class="wide inventory-picklist">
                    {% for group_data in actionable_inventory %}
                        <section class="picklist-group">
                            <div class="picklist-header">
                                <strong>{{ group_data.name }}</strong>
                                <span>{{ group_data.hosts | length }} hosts</span>
                            </div>
                            <div class="picklist-items">
                                {% for host in group_data.hosts %}
                                    <label class="pick-item">
                                        <input type="checkbox" name="selected_hosts" value="{{ group_data.name }}|{{ host.name }}" {% if prefill_group == group_data.name and prefill_host == host.name %}checked{% endif %} {% if not host.ready %}disabled{% endif %}>
                                        <span>{{ host.name }}{% if host.route_target %} -> {{ host.route_target }}{% endif %} {% if not host.ready %}({{ host.reason }}){% endif %}</span>
                                    </label>
                                {% else %}
                                    <span class="workflow-empty">No hosts in this group.</span>
                                {% endfor %}
                            </div>
                        </section>
                    {% endfor %}
                </div>
                <div class="wide button-row">
                    <button class="button" type="submit">Run command on selected hosts</button>
                    <span class="status-pill muted">Explicit host selection is required for remote execution.</span>
                </div>
            </form>
            {% endif %}
        </section>

        <section class="form-shell">
            <div class="section-header">
                <div>
                    <p class="eyebrow">Ansible Controller</p>
                    <h2>Run playbook</h2>
                </div>
            </div>
            {% if bkc_perm.remote_exec %}
            <form method="post" class="form-grid">
                {{ csrf_field() }}
                <input type="hidden" name="action" value="ansible-playbook">
                <label>
                    Playbook
                    <select name="playbook">
                        <option value="">Use configured default</option>
                        {% for playbook in ansible_scan.get('playbooks', []) %}
                            <option value="{{ playbook }}">{{ playbook }}</option>
                        {% endfor %}
                    </select>
                </label>
                <label>
                    Limit
                    <input type="text" name="limit" placeholder="web or web-01">
                </label>
                <label>
                    Extra args
                    <input type="text" name="extra_args" placeholder="--check or -e env=lab">
                </label>
                <div class="wide">
                    <button class="button" type="submit">Run playbook</button>
                </div>
            </form>
            {% endif %}
        </section>
    </section>

    <section class="form-shell top-gap">
        <div class="section-header">
            <div>
                <p class="eyebrow">BKC Template Assets</p>
                <h2>Render and push template</h2>
            </div>
        </div>
        <form method="post" class="form-grid">
            {{ csrf_field() }}
            <input type="hidden" name="action" value="bkc-template">
                <label>
                    Target group
                    <select name="template_group">
                        {% for group_data in actionable_inventory %}
                            <option value="{{ group_data.name }}"{% if prefill_group == group_data.name %} selected{% endif %}>{{ group_data.name }}</option>
                        {% endfor %}
                    </select>
                </label>
            <label>
                Template asset
                <select name="template_asset">
                    {% for asset in template_assets %}
                        <option value="{{ asset.id }}">{{ asset.group }} / {{ asset.name }} -> {{ asset.output }}</option>
                    {% else %}
                        <option value="">No template assets defined</option>
                    {% endfor %}
                </select>
            </label>
            <div class="wide inventory-picklist">
                {% for group_data in actionable_inventory %}
                    <section class="picklist-group">
                        <div class="picklist-header">
                            <strong>{{ group_data.name }}</strong>
                            <span>{{ group_data.hosts | length }} hosts</span>
                        </div>
                        <div class="picklist-items">
                            {% for host in group_data.hosts %}
                                <label class="pick-item">
                                    <input type="checkbox" name="template_selected_hosts" value="{{ group_data.name }}|{{ host.name }}" {% if prefill_group == group_data.name and prefill_host == host.name %}checked{% endif %} {% if not host.ready %}disabled{% endif %}>
                                    <span>{{ host.name }}{% if host.route_target %} -> {{ host.route_target }}{% endif %} {% if not host.ready %}({{ host.reason }}){% endif %}</span>
                                </label>
                            {% else %}
                                <span class="workflow-empty">No hosts in this group.</span>
                            {% endfor %}
                        </div>
                    </section>
                {% endfor %}
            </div>
            <div class="wide button-row">
                <button class="button" type="submit">Apply template asset</button>
                <span class="status-pill muted">This follows the older BKC loop: render template with vars, then push it over SSH.</span>
            </div>
        </form>
    </section>

    <section class="form-shell top-gap">
        <div class="section-header">
            <div>
                <p class="eyebrow">Actionable inventory</p>
                <h2>Resolved command targets</h2>
            </div>
        </div>
        <section class="table-card embedded-table">
            <table>
                <thead>
                    <tr>
                        <th>Group</th>
                        <th>Host</th>
                        <th>Route</th>
                        <th>Status</th>
                    </tr>
                </thead>
                <tbody>
                    {% for group_data in actionable_inventory %}
                        {% for host in group_data.hosts %}
                            <tr>
                                <td>{{ group_data.name }}</td>
                                <td>{{ host.name }}</td>
                                <td>{{ host.route_target or 'unset' }}</td>
                                <td>{{ 'ready' if host.ready else host.reason }}</td>
                            </tr>
                        {% endfor %}
                    {% endfor %}
                </tbody>
            </table>
        </section>
    </section>

    {% if result %}
        <section class="form-shell top-gap">
            <div class="section-header">
                <div>
                    <p class="eyebrow">Execution result</p>
                    <h3>{% if result_buckets %}Grouped host responses{% else %}{{ result.target }}{% endif %}</h3>
                </div>
            </div>
            {% if result_buckets %}
                <section class="group-grid">
                    {% for bucket in result_buckets %}
                        <article class="group-card">
                            <p><strong>Exit status:</strong> {{ bucket.exit_status }}</p>
                            <p><strong>Targets:</strong> {{ bucket.targets | length }}</p>
                            <p>{{ bucket.targets | join(', ') }}</p>
                            <label class="wide top-gap">
                                Stdout
                                <textarea rows="8" readonly>{{ bucket.stdout }}</textarea>
                            </label>
                            <label class="wide top-gap">
                                Stderr
                                <textarea rows="4" readonly>{{ bucket.stderr }}</textarea>
                            </label>
                        </article>
                    {% endfor %}
                </section>
            {% else %}
                <section class="meta-panel">
                    <p><strong>Exit status:</strong> {{ result.exit_status }}</p>
                    <p><strong>Command:</strong> {{ result.command }}</p>
                </section>
                <label class="wide top-gap">
                    Stdout
                    <textarea rows="12" readonly>{{ result.stdout }}</textarea>
                </label>
                <label class="wide top-gap">
                    Stderr
                    <textarea rows="8" readonly>{{ result.stderr }}</textarea>
                </label>
            {% endif %}
        </section>
    {% endif %}

    <section class="form-shell top-gap">
        <div class="section-header">
            <div>
                <p class="eyebrow">Execution memory</p>
                <h3>Recent history</h3>
            </div>
        </div>
        <section class="table-card">
            <table>
                <thead>
                    <tr>
                        <th>When</th>
                        <th>Type</th>
                        <th>Targets</th>
                        <th>Command</th>
                        <th>Buckets</th>
                    </tr>
                </thead>
                <tbody>
                    {% for entry in history %}
                        <tr>
                            <td>{{ entry.timestamp }}</td>
                            <td>{{ entry.type }}</td>
                            <td>{{ entry.targets | length }}</td>
                            <td>{{ entry.command }}</td>
                            <td>{{ entry.bucket_count }}</td>
                        </tr>
                    {% else %}
                        <tr>
                            <td colspan="5">No admin history yet.</td>
                        </tr>
                    {% endfor %}
                </tbody>
            </table>
        </section>
    </section>
{% endblock %}
