{% extends 'base.html.j2' %}
{% from '_macros.html.j2' import csrf_field %}

{% block title %}Pipelines{% endblock %}
{% block page_heading %}Pipelines{% endblock %}

{% block head_extra %}
    <meta http-equiv="refresh" content="8">
{% endblock %}

{% block content %}
    <section class="pipeline-card pipeline-console-filter">
        <div class="pipeline-card-top">
            <div>
                <p class="eyebrow">Pipeline console</p>
                <h3>Catalog, selected lane, runs, and draft creation</h3>
            </div>
            <div class="pipeline-run-meta">
                <span class="status-pill muted">{{ pipelines|length }} lanes</span>
                <span class="status-pill muted">{{ runs|length }} runs</span>
                <span class="status-pill muted">{{ candidates|length }} candidates</span>
            </div>
        </div>
        <form method="get" class="pipeline-filter-form top-gap-sm">
            <label>
                Search
                <input type="text" name="q" value="{{ search_query }}" placeholder="name, repo, workflow, stage">
            </label>
            <label>
                Tag
                <select name="tag">
                    <option value="">all</option>
                    {% for tag in available_tags %}
                        <option value="{{ tag }}" {% if selected_tag == tag %}selected{% endif %}>{{ tag }}</option>
                    {% endfor %}
                </select>
            </label>
            <div class="pipeline-card-actions">
                <button class="button" type="submit">Apply</button>
                <a class="button button-quiet" href="{{ url_for('pipelines.pipelines') }}">Reset</a>
            </div>
        </form>
    </section>

    <section class="pipeline-console-layout top-gap">
        <aside class="pipeline-console-tree">
            <div class="pipeline-console-heading">
                <p class="eyebrow">Catalog tree</p>
                <strong>{{ pipelines|length }} visible</strong>
            </div>
            <div class="pipeline-tree-list">
                {% for pipeline in pipelines %}
                    {% set latest = latest_runs_by_workflow.get(pipeline.workflow) %}
                    {% set supported = supported_workflows.get(pipeline.workflow) %}
                    <a class="pipeline-tree-node{% if selected_pipeline and selected_pipeline.id == pipeline.id %} active{% endif %}"
                       href="{{ url_for('pipelines.pipelines', q=search_query, tag=selected_tag, pipeline=pipeline.id) }}">
                        <span class="pipeline-tree-status status-{{ (latest.status if latest else ('planned' if not supported else 'idle'))|lower|replace(' ', '-') }}"></span>
                        <strong>{{ pipeline.name }}</strong>
                        <small>{{ pipeline.repo }} · {{ pipeline.workflow }}</small>
                    </a>
                {% else %}
                    <div class="workflow-empty">No lanes match this filter.</div>
                {% endfor %}
            </div>

            <div class="pipeline-console-heading top-gap">
                <p class="eyebrow">Create</p>
                <strong>Draft lanes</strong>
            </div>
            <div class="pipeline-tree-list">
                {% for candidate in candidates[:6] %}
                    <form method="post" class="pipeline-candidate-row">
                        {{ csrf_field() }}
                        <input type="hidden" name="action" value="create-candidate-pipeline">
                        <input type="hidden" name="candidate_id" value="{{ candidate.id }}">
                        <button type="submit">
                            <strong>{{ candidate.name }}</strong>
                            <small>{{ candidate.source }} · {{ candidate.kind }}</small>
                        </button>
                    </form>
                {% else %}
                    <div class="workflow-empty">No candidates match this filter.</div>
                {% endfor %}
            </div>
        </aside>

        <section class="pipeline-console-main">
            {% if selected_pipeline %}
                {% set latest = latest_runs_by_workflow.get(selected_pipeline.workflow) %}
                {% set supported = supported_workflows.get(selected_pipeline.workflow) %}
                <article class="pipeline-card pipeline-selected-card">
                    <div class="pipeline-card-top">
                        <div>
                            <p class="eyebrow">{{ selected_pipeline.repo }}</p>
                            <h3>{{ selected_pipeline.name }}</h3>
                        </div>
                        <span class="status-pill {% if latest %}muted{% endif %}">
                            {% if supported %}
                                {{ latest.status if latest else 'not started' }}
                            {% else %}
                                planned
                            {% endif %}
                        </span>
                    </div>
                    <p class="metric-copy">{{ selected_pipeline.description }}</p>

                    <div class="tab-strip pipeline-tabs">
                        <a class="tab-link active" href="#pipeline-summary">Summary</a>
                        <a class="tab-link" href="#pipeline-stages">Stages</a>
                        <a class="tab-link" href="#pipeline-actions">Actions</a>
                        <a class="tab-link" href="#pipeline-runs">Runs</a>
                        <a class="tab-link" href="{{ url_for('pipelines.pipeline_edit', pipeline_id=selected_pipeline.id) }}">Edit</a>
                    </div>

                    <section id="pipeline-summary" class="pipeline-console-section">
                        <div class="pipeline-summary-grid">
                            <div>
                                <p class="eyebrow">Identity</p>
                                <dl class="fact-list">
                                    <div><dt>workflow</dt><dd>{{ selected_pipeline.workflow }}</dd></div>
                                    <div><dt>repo</dt><dd>{{ selected_pipeline.repo }}</dd></div>
                                    <div><dt>stage count</dt><dd>{{ selected_pipeline.stages|length }}</dd></div>
                                    <div><dt>executor</dt><dd>{{ 'wired' if supported else 'planned' }}</dd></div>
                                </dl>
                            </div>
                            <div>
                                <p class="eyebrow">Latest run</p>
                                {% if latest %}
                                    <dl class="fact-list">
                                        <div><dt>run</dt><dd><a href="{{ url_for('pipelines.pipeline_run_detail', run_id=latest.id) }}">{{ latest.id[:8] }}</a></dd></div>
                                        <div><dt>status</dt><dd>{{ latest.status }}</dd></div>
                                        <div><dt>stages</dt><dd>{{ latest.stage_summary.complete }} complete / {{ latest.stages|length }}</dd></div>
                                        <div><dt>updated</dt><dd>{{ latest.updated_at }}</dd></div>
                                    </dl>
                                {% else %}
                                    <p class="metric-copy">No run has been recorded for this lane yet.</p>
                                {% endif %}
                            </div>
                        </div>
                    </section>

                    <section id="pipeline-stages" class="pipeline-console-section">
                        <p class="eyebrow">Stage recipe</p>
                        <div class="pipeline-stage-table">
                            {% for stage in selected_pipeline.stages %}
                                <div>
                                    <span>{{ loop.index }}</span>
                                    <strong>{{ stage }}</strong>
                                </div>
                            {% endfor %}
                        </div>
                    </section>

                    <section id="pipeline-actions" class="pipeline-console-section">
                        <p class="eyebrow">Action bricks</p>
                        <div class="pipeline-stage-row">
                            {% for action in selected_pipeline.actions %}
                                <a class="pipeline-stage-chip compact-chip" href="{{ url_for('resource_graph.resource_graph', kind='action', resource='action:' ~ action) }}">{{ action }}</a>
                            {% else %}
                                <span class="pipeline-stage-chip compact-chip">action catalog pending</span>
                            {% endfor %}
                        </div>
                    </section>

                    <section id="pipeline-runs" class="pipeline-console-section">
                        <form method="post" class="pipeline-trigger-form">
                            {{ csrf_field() }}
                            <input type="hidden" name="pipeline_id" value="{{ selected_pipeline.id }}">
                            <label>
                                Ref
                                <input type="text" name="ref" value="refs/heads/main">
                            </label>
                            <label>
                                Commit
                                <input type="text" name="commit" placeholder="optional commit sha">
                            </label>
                            {% if selected_pipeline.workflow == 'fedora-cosmic-postinstall' %}
                                <label>
                                    Target host
                                    <input type="text" name="target_host" placeholder="192.168.1.129">
                                </label>
                                <label>
                                    Target VMID
                                    <input type="text" name="target_vmid" placeholder="optional">
                                </label>
                                <label class="wide">
                                    Target name
                                    <input type="text" name="target_name" placeholder="fedora-template-118">
                                </label>
                            {% endif %}
                            <label class="wide">
                                Notes
                                <textarea name="notes" rows="3" placeholder="{{ selected_pipeline.notes }}"></textarea>
                            </label>
                            <div class="pipeline-card-actions">
                                <button class="button" type="submit" {% if not supported %}disabled{% endif %}>
                                    {{ 'Queue Run' if supported else 'Planned Lane' }}
                                </button>
                                <a class="button button-quiet" href="{{ url_for('pipelines.pipeline_edit', pipeline_id=selected_pipeline.id) }}">Edit Lane</a>
                            </div>
                        </form>
                    </section>

                    <div class="pipeline-inline-links">
                        {% for link in selected_pipeline.links %}
                            <a class="button button-quiet" href="{{ link.url }}">{{ link.label }}</a>
                        {% endfor %}
                    </div>
                </article>
            {% else %}
                <section class="group-card empty-state">
                    <h4>No lane selected</h4>
                    <p>Clear the search or tag filter to see the catalog.</p>
                </section>
            {% endif %}
        </section>
    </section>

    <section class="section-header">
        <div>
            <p class="eyebrow">Recent automation runs</p>
            <h3>Run ledger</h3>
        </div>
    </section>

    <section class="pipeline-run-list">
        {% for run in runs %}
            <article class="pipeline-run-card">
                <div class="pipeline-card-top">
                    <div>
                        <p class="eyebrow">{{ run.repo }}</p>
                        <h3>{{ run.workflow }}</h3>
                    </div>
                    <span class="status-pill">{{ run.status }}</span>
                </div>
                <p class="metric-copy">{{ run.notes or 'no notes' }}</p>
                <div class="pipeline-run-meta">
                    <span class="status-pill muted">Run {{ run.id[:8] }}</span>
                    <span class="status-pill muted">{{ run.ref or 'ref unset' }}</span>
                    {% if run.commit %}
                        <span class="status-pill muted">{{ run.commit[:12] }}</span>
                    {% endif %}
                    {% for tag in run.tags %}
                        <span class="pipeline-stage-chip compact-chip">{{ tag }}</span>
                    {% endfor %}
                </div>
                <div class="pipeline-stage-board">
                    {% for stage in run.stages %}
                        <div class="pipeline-stage-status status-{{ stage.status|lower|replace(' ', '-') }}">
                            <strong>{{ stage.name }}</strong>
                            <span>{{ stage.status }}</span>
                            {% if stage.detail %}
                                <small>{{ stage.detail }}</small>
                            {% endif %}
                        </div>
                    {% endfor %}
                </div>
                {% set last_event = (run.events|default([], true)|last) %}
                <div class="pipeline-run-summary">
                    {% if last_event %}
                        <span class="status-pill muted">{{ last_event.at }}</span>
                        <span class="status-pill muted">{{ last_event.stage }}</span>
                        <span class="metric-copy">{{ last_event.message }}</span>
                    {% else %}
                        <span class="metric-copy">No events recorded yet.</span>
                    {% endif %}
                </div>
                <div class="pipeline-card-actions top-gap-sm">
                    <a class="button" href="{{ url_for('pipelines.pipeline_run_detail', run_id=run.id) }}">Open Run</a>
                    <a class="button button-quiet" href="{{ url_for('pipelines.pipeline_edit', pipeline_id=run.extra.pipeline_id) }}">Edit Lane</a>
                    <form method="post" action="{{ url_for('pipelines.pipeline_run_action', run_id=run.id) }}" class="inline-action-form">
                        {{ csrf_field() }}
                        <input type="hidden" name="action" value="retry">
                        <button class="button button-quiet" type="submit">Retry</button>
                    </form>
                    <form method="post" action="{{ url_for('pipelines.pipeline_run_action', run_id=run.id) }}" class="inline-action-form">
                        {{ csrf_field() }}
                        <input type="hidden" name="action" value="redeploy">
                        <button class="button button-quiet" type="submit">Redeploy</button>
                    </form>
                    {% if run.workflow in ('monitoring-stack', 'microblog-publish') %}
                        <form method="post" action="{{ url_for('pipelines.pipeline_run_action', run_id=run.id) }}" class="inline-action-form">
                            {{ csrf_field() }}
                            <input type="hidden" name="action" value="undeploy">
                            <button class="button button-quiet" type="submit">Undeploy</button>
                        </form>
                    {% endif %}
                </div>
            </article>
        {% else %}
            <section class="group-card empty-state">
                <h4>No automation runs yet</h4>
                <p>Queue a demo lane above to start building the run ledger.</p>
            </section>
        {% endfor %}
    </section>
{% endblock %}
