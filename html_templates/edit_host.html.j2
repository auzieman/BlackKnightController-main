{% extends 'base.html.j2' %}
{% from '_macros.html.j2' import csrf_field %}

{% block title %}Edit Host{% endblock %}

{% block content %}
    <section class="form-shell">
        <div class="section-header">
            <div>
                <p class="eyebrow">Node metadata</p>
                <h2>{{ host }}</h2>
            </div>
        </div>
        <form method="post" class="form-grid">
            {{ csrf_field() }}
            <label>
                User
                <input type="text" name="user" value="{{ host_data.user or '' }}">
            </label>
            <label>
                Port
                <input type="number" name="port" value="{{ host_data.port or 22 }}">
            </label>
            <label class="wide">
                Private key
                <input type="text" name="private_key" value="{{ host_data.private_key or '' }}">
            </label>
            <label>
                Provider
                <input type="text" name="provider" value="{{ host_data.provider or 'proxmox' }}">
            </label>
            <label>
                Provisioner
                <input type="text" name="provisioner" value="{{ host_data.provisioner or 'cloud-init' }}">
            </label>
            <label>
                Configuration
                <input type="text" name="configuration" value="{{ host_data.configuration or 'ansible' }}">
            </label>
            <label>
                State
                <input type="text" name="state" value="{{ host_data.state or 'planned' }}">
            </label>
            <label>
                Application
                <input type="text" name="application" value="{{ host_data.application or 'bkc-managed' }}">
            </label>
            <div class="wide">
                <button class="button" type="submit">Save node</button>
            </div>
        </form>
    </section>
{% endblock %}
