{% extends 'base.html.j2' %}
{% from '_macros.html.j2' import csrf_field %}

{% block title %}Integrations{% endblock %}

{% block content %}
    <section class="section-header">
        <div>
            <p class="eyebrow">Infrastructure controls</p>
            <h2>Integrations</h2>
        </div>
    </section>

    <section class="builder-layout">
        <article class="form-shell">
            <h3>Proxmox API</h3>
            <form method="post" class="form-grid">
                {{ csrf_field() }}
                <input type="hidden" name="action" value="save-proxmox">
                <label class="wide">
                    API URL
                    <input type="text" name="api_url" value="{{ integrations.proxmox.api_url }}" placeholder="https://192.168.1.9:8006/api2/json">
                </label>
                <label>
                    Token name
                    <input type="text" name="token_name" value="{{ integrations.proxmox.token_name }}" placeholder="bkc">
                </label>
                <label>
                    Token value
                    <input type="password" name="token_value" value="{{ integrations.proxmox.token_value }}">
                </label>
                <label>
                    Username
                    <input type="text" name="username" value="{{ integrations.proxmox.username }}" placeholder="root@pam">
                </label>
                <label>
                    Password
                    <input type="password" name="password" value="{{ integrations.proxmox.password }}">
                </label>
                <label class="checkbox-row wide">
                    <input type="checkbox" name="verify_ssl" {% if integrations.proxmox.verify_ssl %}checked{% endif %}>
                    Verify SSL certificate
                </label>
                <div class="wide button-row">
                    <button class="button" type="submit">Save Proxmox settings</button>
                </div>
            </form>
            <form method="post" class="inline-form">
                {{ csrf_field() }}
                <input type="hidden" name="action" value="test-proxmox">
                <button class="button secondary" type="submit">Test Proxmox connection</button>
            </form>
            <form method="post" class="inline-form">
                {{ csrf_field() }}
                <input type="hidden" name="action" value="pull-proxmox-inventory">
                <button class="button secondary" type="submit">Pull Proxmox inventory</button>
            </form>
            <form method="post" class="inline-form">
                {{ csrf_field() }}
                <input type="hidden" name="action" value="sync-proxmox-inventory">
                <button class="button secondary" type="submit">Sync Proxmox inventory into BKC</button>
            </form>
        </article>

        <article class="form-shell">
            <h3>Ansible Controller</h3>
            <form method="post" class="form-grid">
                {{ csrf_field() }}
                <input type="hidden" name="action" value="save-ansible">
                <label>
                    Controller host
                    <input type="text" name="controller_host" value="{{ integrations.ansible.controller_host }}" placeholder="192.168.1.10">
                </label>
                <label>
                    Controller user
                    <input type="text" name="controller_user" value="{{ integrations.ansible.controller_user }}" placeholder="ansible">
                </label>
                <label>
                    Controller password
                    <input type="password" name="controller_password" value="{{ integrations.ansible.controller_password }}">
                </label>
                <label>
                    Playbook
                    <input type="text" name="playbook" value="{{ integrations.ansible.playbook }}" placeholder="site.yml">
                </label>
                <label>
                    Inventory path
                    <input type="text" name="inventory_path" value="{{ integrations.ansible.inventory_path }}" placeholder="/srv/ansible/inventory">
                </label>
                <label>
                    Config root
                    <input type="text" name="config_root" value="{{ integrations.ansible.config_root }}" placeholder="/etc/ansible">
                </label>
                <div class="wide">
                    <button class="button" type="submit">Save Ansible settings</button>
                </div>
            </form>
            <form method="post" class="inline-form">
                {{ csrf_field() }}
                <input type="hidden" name="action" value="scan-ansible">
                <button class="button secondary" type="submit">Scan Ansible config</button>
            </form>
            <form method="post" class="inline-form">
                {{ csrf_field() }}
                <input type="hidden" name="action" value="sync-ansible-inventory">
                <button class="button secondary" type="submit">Sync Ansible inventory into BKC</button>
            </form>
        </article>

        <article class="form-shell">
            <h3>Docker Swarm Manager</h3>
            <form method="post" class="form-grid">
                {{ csrf_field() }}
                <input type="hidden" name="action" value="save-docker">
                <label>
                    Manager host
                    <input type="text" name="manager_host" value="{{ integrations.docker.manager_host }}" placeholder="swarm1.lab.auzietek.com">
                </label>
                <label>
                    Manager user
                    <input type="text" name="manager_user" value="{{ integrations.docker.manager_user }}" placeholder="root">
                </label>
                <label>
                    Manager password
                    <input type="password" name="manager_password" value="{{ integrations.docker.manager_password }}">
                </label>
                <label>
                    Docker context
                    <input type="text" name="context_name" value="{{ integrations.docker.context_name }}" placeholder="auzix-swarm">
                </label>
                <label>
                    API endpoint
                    <input type="text" name="api_endpoint" value="{{ integrations.docker.api_endpoint }}" placeholder="ssh://root@swarm1.lab.auzietek.com">
                </label>
                <label>
                    API mode
                    <select name="api_mode">
                        <option value="host" {% if integrations.docker.api_mode == 'host' %}selected{% endif %}>Docker host</option>
                        <option value="context" {% if integrations.docker.api_mode == 'context' %}selected{% endif %}>Docker context</option>
                        <option value="ssh" {% if integrations.docker.api_mode == 'ssh' %}selected{% endif %}>SSH fallback</option>
                    </select>
                </label>
                <label>
                    Preferred stack
                    <input type="text" name="stack_name" value="{{ integrations.docker.stack_name }}" placeholder="blackknight">
                </label>
                <div class="wide">
                    <button class="button" type="submit">Save Docker settings</button>
                </div>
            </form>
            <form method="post" class="inline-form">
                {{ csrf_field() }}
                <input type="hidden" name="action" value="scan-docker">
                <button class="button secondary" type="submit">Scan Docker Swarm</button>
            </form>
            <form method="post" class="inline-form">
                {{ csrf_field() }}
                <input type="hidden" name="action" value="sync-docker-inventory">
                <button class="button secondary" type="submit">Sync Docker inventory into BKC</button>
            </form>
        </article>

        <article class="form-shell">
            <h3>Kubernetes API</h3>
            <form method="post" class="form-grid">
                {{ csrf_field() }}
                <input type="hidden" name="action" value="save-kubernetes">
                <label>
                    Cluster name
                    <input type="text" name="cluster_name" value="{{ integrations.kubernetes.cluster_name }}" placeholder="auzix-k3s">
                </label>
                <label>
                    API URL
                    <input type="text" name="kubernetes_api_url" value="{{ integrations.kubernetes.api_url }}" placeholder="https://kube1.lab.auzietek.com:6443">
                </label>
                <label>
                    Kubeconfig path
                    <input type="text" name="kubeconfig_path" value="{{ integrations.kubernetes.kubeconfig_path }}" placeholder="~/.kube/config">
                </label>
                <label>
                    Context
                    <input type="text" name="kubernetes_context" value="{{ integrations.kubernetes.context }}" placeholder="auzix-k3s">
                </label>
                <label>
                    Namespace
                    <input type="text" name="kubernetes_namespace" value="{{ integrations.kubernetes.namespace }}" placeholder="auzix-build">
                </label>
                <label class="checkbox-row wide">
                    <input type="checkbox" name="kubernetes_verify_ssl" {% if integrations.kubernetes.verify_ssl %}checked{% endif %}>
                    Verify Kubernetes certificate
                </label>
                <div class="wide">
                    <button class="button" type="submit">Save Kubernetes settings</button>
                </div>
            </form>
            <form method="post" class="inline-form">
                {{ csrf_field() }}
                <input type="hidden" name="action" value="scan-kubernetes">
                <button class="button secondary" type="submit">Scan Kubernetes cluster</button>
            </form>
        </article>
    </section>

    <section class="form-shell">
        <h3>SSH Automation Key</h3>
        <form method="post" class="form-grid">
            {{ csrf_field() }}
            <input type="hidden" name="action" value="save-ssh">
            <label>
                Key name
                <input type="text" name="key_name" value="{{ integrations.ssh.key_name }}" placeholder="bkc_id_rsa">
            </label>
            <div class="wide">
                <button class="button" type="submit">Save SSH settings</button>
            </div>
        </form>
        <form method="post" class="inline-form">
            {{ csrf_field() }}
            <input type="hidden" name="action" value="generate-ssh-key">
            <button class="button secondary" type="submit">Generate SSH key pair</button>
        </form>
        <section class="meta-panel">
            <p><strong>Private key:</strong> {{ ssh_key.private_key_path }}</p>
            <p><strong>Public key:</strong> {{ ssh_key.public_key_path }}</p>
        </section>
        <label class="wide top-gap">
            Public key
            <textarea rows="4" readonly>{{ ssh_key.public_key }}</textarea>
        </label>
    </section>

    {% if proxmox_inventory %}
        <section class="form-shell">
            <div class="section-header">
                <div>
                    <p class="eyebrow">Pulled from Proxmox</p>
                    <h3>Inventory snapshot</h3>
                </div>
            </div>
            <section class="meta-panel">
                <p><strong>Version:</strong> {{ proxmox_inventory.version.version }}</p>
                <p><strong>Release:</strong> {{ proxmox_inventory.version.release }}</p>
                <p><strong>Nodes:</strong> {{ proxmox_inventory.nodes | length }}</p>
                <p><strong>QEMU VMs:</strong> {{ proxmox_inventory.virtual_machines | length }}</p>
                <p><strong>LXCs:</strong> {{ proxmox_inventory.containers | length }}</p>
            </section>
            <section class="table-card top-gap">
                <table>
                    <thead>
                        <tr>
                            <th>VMID</th>
                            <th>Name</th>
                            <th>Node</th>
                            <th>Status</th>
                            <th>Type</th>
                            <th>IP</th>
                        </tr>
                    </thead>
                    <tbody>
                        {% for vm in proxmox_inventory.virtual_machines %}
                            <tr>
                                <td>{{ vm.vmid }}</td>
                                <td>{{ vm.name or 'unnamed' }}</td>
                                <td>{{ vm.node or 'unknown' }}</td>
                                <td>{{ vm.status or 'unknown' }}</td>
                                <td>{{ vm.type or 'qemu' }}</td>
                                <td>{{ vm.ip | default('n/a', true) }}</td>
                            </tr>
                        {% else %}
                            <tr>
                                <td colspan="6">No QEMU VMs returned.</td>
                            </tr>
                        {% endfor %}
                    </tbody>
                </table>
            </section>
            <label class="wide top-gap">
                API request trace
                <textarea rows="8" readonly>{% for req in proxmox_inventory.request_trace %}{{ req.method }} {{ req.path }}
{% endfor %}</textarea>
            </label>
        </section>
    {% endif %}

    {% if ansible_scan %}
        <section class="form-shell">
            <div class="section-header">
                <div>
                    <p class="eyebrow">Scanned from Ansible</p>
                    <h3>Ansible snapshot</h3>
                </div>
            </div>
            <section class="meta-panel">
                <p><strong>Controller:</strong> {{ ansible_scan.controller_user }}@{{ ansible_scan.controller_host }}</p>
                <p><strong>Inventory path:</strong> {{ ansible_scan.inventory_path }}</p>
                <p><strong>Config root:</strong> {{ ansible_scan.config_root }}</p>
                <p><strong>Auth:</strong> {{ ansible_scan.auth_method }}</p>
                <p><strong>Playbooks:</strong> {{ ansible_scan.playbooks | length }}</p>
            </section>
            <label class="wide top-gap">
                Inventory file
                <textarea rows="10" readonly>{{ ansible_scan.inventory_content }}</textarea>
            </label>
            <section class="table-card top-gap">
                <table>
                    <thead>
                        <tr>
                            <th>Playbook</th>
                        </tr>
                    </thead>
                    <tbody>
                        {% for playbook in ansible_scan.playbooks %}
                            <tr>
                                <td>{{ playbook }}</td>
                            </tr>
                        {% else %}
                            <tr>
                                <td>No YAML playbooks found under the configured root.</td>
                            </tr>
                        {% endfor %}
                    </tbody>
                </table>
            </section>
        </section>
    {% endif %}

    {% if docker_scan %}
        <section class="form-shell">
            <div class="section-header">
                <div>
                    <p class="eyebrow">Scanned from Docker</p>
                    <h3>Docker Swarm snapshot</h3>
                </div>
            </div>
            <section class="meta-panel">
                <p><strong>Manager:</strong> {{ docker_scan.manager_user }}@{{ docker_scan.manager_host }}</p>
                <p><strong>Auth:</strong> {{ docker_scan.auth_method }}</p>
                <p><strong>Local node state:</strong> {{ docker_scan.swarm.LocalNodeState | default('unknown', true) }}</p>
                <p><strong>Nodes:</strong> {{ docker_scan.nodes | length }}</p>
                <p><strong>Stacks:</strong> {{ docker_scan.stacks | length }}</p>
                <p><strong>Services:</strong> {{ docker_scan.services | length }}</p>
            </section>
            <section class="table-card top-gap">
                <table>
                    <thead>
                        <tr>
                            <th>Node</th>
                            <th>Status</th>
                            <th>Availability</th>
                            <th>Manager</th>
                            <th>Engine</th>
                        </tr>
                    </thead>
                    <tbody>
                        {% for node in docker_scan.nodes %}
                            <tr>
                                <td>{{ node.Hostname or node.Name or node.raw or 'unknown' }}</td>
                                <td>{{ node.Status or 'unknown' }}</td>
                                <td>{{ node.Availability or 'unknown' }}</td>
                                <td>{{ node.ManagerStatus or '-' }}</td>
                                <td>{{ node.EngineVersion or '-' }}</td>
                            </tr>
                        {% else %}
                            <tr>
                                <td colspan="5">No swarm nodes returned.</td>
                            </tr>
                        {% endfor %}
                    </tbody>
                </table>
            </section>
            <section class="table-card top-gap">
                <table>
                    <thead>
                        <tr>
                            <th>Stack</th>
                            <th>Services</th>
                            <th>Orchestrator</th>
                        </tr>
                    </thead>
                    <tbody>
                        {% for stack in docker_scan.stacks %}
                            <tr>
                                <td>{{ stack.Name or stack.raw or 'unknown' }}</td>
                                <td>{{ stack.Services or '-' }}</td>
                                <td>{{ stack.Orchestrator or '-' }}</td>
                            </tr>
                        {% else %}
                            <tr>
                                <td colspan="3">No stacks returned.</td>
                            </tr>
                        {% endfor %}
                    </tbody>
                </table>
            </section>
        </section>
    {% endif %}

    {% if kubernetes_scan %}
        <section class="form-shell">
            <div class="section-header">
                <div>
                    <p class="eyebrow">Scanned from Kubernetes</p>
                    <h3>Kubernetes snapshot</h3>
                </div>
            </div>
            <section class="meta-panel">
                <p><strong>Cluster:</strong> {{ kubernetes_scan.cluster_name }}</p>
                <p><strong>Context:</strong> {{ kubernetes_scan.context }}</p>
                <p><strong>Namespace:</strong> {{ kubernetes_scan.namespace }}</p>
                <p><strong>Nodes:</strong> {{ kubernetes_scan.nodes | length }}</p>
                <p><strong>Namespaces:</strong> {{ kubernetes_scan.namespaces | length }}</p>
                <p><strong>Pods:</strong> {{ kubernetes_scan.pods | length }}</p>
                <p><strong>Services:</strong> {{ kubernetes_scan.services | length }}</p>
            </section>
            <section class="table-card top-gap">
                <table>
                    <thead>
                        <tr>
                            <th>Node</th>
                            <th>Role</th>
                            <th>Ready</th>
                            <th>IP</th>
                            <th>Kubelet</th>
                            <th>Runtime</th>
                        </tr>
                    </thead>
                    <tbody>
                        {% for node in kubernetes_scan.nodes %}
                            <tr>
                                <td>{{ node.name or 'unknown' }}</td>
                                <td>{{ node.role or '-' }}</td>
                                <td>{{ node.ready or 'unknown' }}</td>
                                <td>{{ node.internal_ip or '-' }}</td>
                                <td>{{ node.kubelet or '-' }}</td>
                                <td>{{ node.container_runtime or '-' }}</td>
                            </tr>
                        {% else %}
                            <tr>
                                <td colspan="6">No Kubernetes nodes returned.</td>
                            </tr>
                        {% endfor %}
                    </tbody>
                </table>
            </section>
        </section>
    {% endif %}
{% endblock %}
