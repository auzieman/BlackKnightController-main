<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>{% block title %}BlackKnightController{% endblock %}</title>
    <link rel="stylesheet" href="{{ url_for('static', filename='main.css') }}">
    {% block head_extra %}{% endblock %}
</head>
<body>
    <div class="starfield"></div>
    {% set workspace_wide = request.endpoint and (request.endpoint.startswith('pipelines.') or request.endpoint == 'inventory_console.inventory_console' or request.endpoint == 'resource_graph.resource_graph') %}
    <div class="shell {% if request.endpoint == 'auth.login' %}shell-login{% endif %} {% if workspace_wide %}shell-workspace{% endif %}">
        {% if request.endpoint != 'auth.login' %}
        <aside class="app-rail">
            <a class="rail-mark" href="{{ url_for('index.index') }}" title="Overview">BKC</a>
            <nav class="rail-nav" aria-label="Primary">
                <a class="{% if request.endpoint == 'resource_graph.resource_graph' %}active{% endif %}" href="{{ url_for('resource_graph.resource_graph') }}" title="Resource Graph">RG</a>
                <a class="{% if request.endpoint == 'inventory_console.inventory_console' %}active{% endif %}" href="{{ url_for('inventory_console.inventory_console') }}" title="Inventory">IN</a>
                <a class="{% if request.endpoint and request.endpoint.startswith('pipelines.') %}active{% endif %}" href="{{ url_for('pipelines.pipelines') }}" title="Pipelines">PL</a>
                <a class="{% if request.endpoint == 'integrations.integrations' %}active{% endif %}" href="{{ url_for('integrations.integrations') }}" title="Integrations">API</a>
            </nav>
        </aside>
        <aside class="sidebar">
            <div class="brand-block">
                <p class="eyebrow">BlackKnightController CE</p>
                <h1>Resource Ops</h1>
                <div class="status-chip">Graph-linked console</div>
            </div>
            <nav>
                <ul class="nav-list">
                    <li><a class="{% if request.endpoint == 'index.index' %}active{% endif %}" href="{{ url_for('index.index') }}">Overview</a></li>
                    <li><a class="{% if request.endpoint == 'resource_graph.resource_graph' %}active{% endif %}" href="{{ url_for('resource_graph.resource_graph') }}">Resource Graph</a></li>
                    <li><a class="{% if request.endpoint == 'inventory_console.inventory_console' %}active{% endif %}" href="{{ url_for('inventory_console.inventory_console') }}">Inventory</a></li>
                    <li><a class="{% if request.endpoint and request.endpoint.startswith('groups.') %}active{% endif %}" href="{{ url_for('groups.list_groups') }}">Groups</a></li>
                    <li><a class="{% if request.endpoint and request.endpoint.startswith('pipelines.') %}active{% endif %}" href="{{ url_for('pipelines.pipelines') }}">Pipelines</a></li>
                    <li><a class="{% if request.endpoint == 'builder.builder' %}active{% endif %}" href="{{ url_for('builder.builder') }}">Inventory Builder</a></li>
                    <li><a class="{% if request.endpoint == 'admin.admin' %}active{% endif %}" href="{{ url_for('admin.admin') }}">Admin Mode</a></li>
                    <li><a class="{% if request.endpoint == 'integrations.integrations' %}active{% endif %}" href="{{ url_for('integrations.integrations') }}">Integrations</a></li>
                    <li><a class="{% if request.endpoint == 'proxmox_ops.proxmox_ops' %}active{% endif %}" href="{{ url_for('proxmox_ops.proxmox_ops') }}">Proxmox Ops</a></li>
                    <li><a class="{% if request.endpoint == 'add_nodes.add_nodes' %}active{% endif %}" href="{{ url_for('add_nodes.add_nodes') }}">Bulk Add Nodes</a></li>
                    <li><a class="{% if request.endpoint and request.endpoint.startswith('templates.') %}active{% endif %}" href="{{ url_for('templates.list_templates') }}">Templates</a></li>
                    {% if bkc_job_queue %}
                        <li><a class="{% if request.endpoint and request.endpoint.startswith('jobs.') %}active{% endif %}" href="{{ url_for('jobs.jobs_home') }}">Jobs</a></li>
                    {% endif %}
                    {% if bkc_user and bkc_user.is_superuser %}
                        <li><a class="{% if request.endpoint and request.endpoint.startswith('settings.') %}active{% endif %}" href="{{ url_for('settings.settings_home') }}">Platform settings</a></li>
                    {% endif %}
                </ul>
            </nav>
            <section class="sidebar-resource-tree">
                <div class="tree-caption">
                    <span>Resources</span>
                    <a href="{{ url_for('resource_graph.resource_graph') }}">Open</a>
                </div>
                {% for group in bkc_resource_nav_tree %}
                    {% if group.resources %}
                        <details class="sidebar-tree-group" {% if loop.index <= 4 %}open{% endif %}>
                            <summary>
                                <span>{{ group.meta.short }} {{ group.meta.label }}</span>
                                <span>{{ group.resources|length }}</span>
                            </summary>
                            <div class="sidebar-tree-children">
                                {% for resource in group.resources[:8] %}
                                    <a href="{{ url_for('resource_graph.resource_graph', resource=resource.id) }}">
                                        <strong>{{ resource.name }}</strong>
                                        <span>{{ resource.state }}</span>
                                    </a>
                                {% endfor %}
                            </div>
                        </details>
                    {% endif %}
                {% endfor %}
            </section>
        </aside>
        {% endif %}
        <main class="main {% if request.endpoint == 'auth.login' %}main-login{% endif %}">
            {% if request.endpoint != 'auth.login' %}
            <header class="topbar">
                <div>
                    <p class="eyebrow">Workbench View</p>
                    <h2>{% block page_heading %}Flight Deck{% endblock %}</h2>
                </div>
                <div class="topbar-actions">
                    {% if current_user.is_authenticated %}
                        {% if bkc_memberships|length > 1 or (bkc_user and bkc_user.is_superuser) %}
                            <form method="post" action="{{ url_for('auth.switch_tenant') }}" class="tenant-switch">
                                {% from '_macros.html.j2' import csrf_field %}{{ csrf_field() }}
                                <label class="eyebrow-inline">Tenant
                                    <select name="slug" class="input-like input-compact" onchange="this.form.submit()">
                                        {% if bkc_user and bkc_user.is_superuser %}
                                            {% for t in bkc_all_tenants %}
                                                <option value="{{ t.slug }}" {% if t.slug == bkc_tenant_slug %}selected{% endif %}>{{ t.slug }}</option>
                                            {% endfor %}
                                        {% else %}
                                            {% for m in bkc_memberships %}
                                                <option value="{{ m.slug }}" {% if m.slug == bkc_tenant_slug %}selected{% endif %}>{{ m.slug }}</option>
                                            {% endfor %}
                                        {% endif %}
                                    </select>
                                </label>
                                <noscript><button type="submit" class="button button-quiet">Switch</button></noscript>
                            </form>
                        {% endif %}
                        <span class="status-pill muted">{{ bkc_username }}</span>
                        <form method="post" action="{{ url_for('auth.logout') }}" class="inline-logout">
                            {% from '_macros.html.j2' import csrf_field %}{{ csrf_field() }}
                            <button type="submit" class="button button-quiet">Sign out</button>
                        </form>
                    {% endif %}
                </div>
            </header>
            {% else %}
            <header class="topbar">
                <div>
                    <p class="eyebrow">Session</p>
                    <h2>Sign in</h2>
                </div>
            </header>
            {% endif %}
            {% with messages = get_flashed_messages(with_categories=true) %}
                {% if messages %}
                    <section class="flash-stack">
                        {% for category, message in messages %}
                            <div class="flash {% if category == 'error' %}flash-error{% endif %}">{{ message }}</div>
                        {% endfor %}
                    </section>
                {% endif %}
            {% endwith %}
            {% block content %}{% endblock %}
        </main>
    </div>
</body>
</html>
